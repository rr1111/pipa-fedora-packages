maintainer="bluebunny <kalorin.bok084@passinbox.com>"
_flavor="xiaomi-pipa"
pkgname=linux-$_flavor
pkgver=6.19.12
pkgrel=0
pkgdesc="Stable kernel for Xiaomi Pad 6"
arch="aarch64"
_carch="arm64"
url="https://kernel.org"
license="GPL-2.0-only"
options="
	!check
	!strip
	!tracedeps
	pmb:cross-native
	pmb:kconfigcheck-community
	pmb:kconfigcheck-immutable
	pmb:kconfigcheck-rust
"
makedepends="
	bison
	clang
	clang-libclang
	diffutils
	elfutils-dev
	findutils
	flex
	linux-headers
	lld
	llvm
	openssl-dev
	pahole
	perl
	postmarketos-installkernel
	python3
	rust
	rust-bindgen
	rust-src
	rustfmt
	sed
	zstd
"

source="
	linux-$pkgver.tar.xz::https://cdn.kernel.org/pub/linux/kernel/v${pkgver%%.*}.x/linux-$pkgver.tar.xz
	config-$_flavor.aarch64

	0001-arm64-dts-qcom-sm8250-xiaomi-pipa-Add-device-tree-fo.patch
	0002-power-supply-Add-driver-for-Qualcomm-PMIC-fuel-gauge.patch
	0003-Input-Add-nt36523-touchscreen-driver.patch
	0004-drm-Add-drm-notifier-support.patch
	0005-drm-dsi-emit-panel-turn-on-off-signal-to-touchscreen.patch
	0006-drm-msm-dsi-change-sync-mode-to-sync-on-DSI0-rather-.patch
	0007-drm-msm-dsi-support-DSC-configurations-with-slice_pe.patch
	0008-drm-panel-Add-support-for-Novatek-NT36532-panel.patch
	0009-drivers-media-i2c-ov13b10-add-device-tree-support-an.patch
	0010-ASoC-codecs-aw88261-add-hacks-for-xiaomi-pipa.patch
	0011-ASoC-qcom-sm8250-Add-tdm-support.patch
"
builddir="$srcdir/linux-$pkgver"

prepare() {
	default_prepare
	cp "$srcdir/config-$_flavor.$arch" .config
}

build() {
	unset LDFLAGS
	make ARCH="$_carch" LLVM=1 \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-$_flavor"
}

package() {
	make modules_install zinstall dtbs_install \
		ARCH="$_carch" \
		LLVM=1 \
		INSTALL_PATH="$pkgdir"/boot/ \
		INSTALL_MOD_PATH="$pkgdir" \
		INSTALL_MOD_STRIP=1 \
		INSTALL_DTBS_PATH="$pkgdir"/boot/dtbs

	install -D "$builddir/arch/$_carch/boot/Image.gz" \
		"$pkgdir/boot/vmlinuz"

	rm -f "$pkgdir"/lib/modules/*/build "$pkgdir"/lib/modules/*/source

	install -D "$builddir"/include/config/kernel.release \
		"$pkgdir"/usr/share/kernel/$_flavor/kernel.release
}

